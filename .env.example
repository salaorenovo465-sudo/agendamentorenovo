GOOGLE_APPLICATION_CREDENTIALS=service-account-key.json
# Alternativa para deploys sem arquivo local:
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# GOOGLE_SERVICE_ACCOUNT_BASE64=eyJ0eXBlIjoic2VydmljZV9hY2NvdW50IiwuLi59
GOOGLE_CALENDAR_ID=seu_email_da_agenda@gmail.com
GOOGLE_CALENDAR_ICS_URL=https://calendar.google.com/calendar/ical/seu_email_da_agenda%40gmail.com/private-token/basic.ics
CALENDAR_TIMEZONE=America/Sao_Paulo
TZ_OFFSET_HOURS=-3
SUPABASE_URL=https://SEU-PROJETO.supabase.co
SUPABASE_PROJECT_REF=seu_project_ref
SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key
SUPABASE_DB_URL=postgresql://postgres.<project_ref>:<password>@aws-1-sa-east-1.pooler.supabase.com:6543/postgres
ADMIN_API_KEY=defina_uma_chave_forte_para_o_painel
# Opcional: aceite mais de uma chave separando por virgula
# ADMIN_API_KEY=chave_nova,chave_antiga
NODE_ENV=production
ALLOW_LOCALHOST_CORS=false
DEFAULT_TENANT_SLUG=renovo
DEFAULT_TENANT_NAME=Estudio Renovo
PUBLIC_APP_URL=https://agendamentorenovo.vercel.app
RENDER_EXTERNAL_URL=https://agendamentorenovo-api.onrender.com
VITE_ADMIN_PATH=renovo-admin
VITE_DEFAULT_TENANT=renovo
VITE_WHATSAPP_WORKSPACE_ENABLED=false
VITE_WHATSAPP_PROVIDER=chatwoot
VITE_CHATWOOT_URL=http://20.226.48.76:8080
VITE_CHATWOOT_ACCOUNT_ID=1
VITE_CHATWOOT_EMAIL=admin@renovo.app
WHATSAPP_FEATURE_ENABLED=false
BAILEYS_ENABLED=false
# Baileys e legado/opcional. Producao deve usar Evolution API.
# BAILEYS_AUTO_CONNECT=false
# BAILEYS_AUTH_DIR=C:\\Users\\SEU_USUARIO\\.agendamentorenovo\\baileys_auth
# BAILEYS_SALON_WHATSAPP=5571999999999
# BAILEYS_LOG_LEVEL=silent
PORT=3101
# Opcional: use quando o front e a API estiverem em dominios diferentes
# VITE_API_URL=https://api.seu-dominio.com
VITE_DEV_API_PROXY_TARGET=http://localhost:3101
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
WHATSAPP_CONTROL_RATE_LIMIT_WINDOW_MS=60000
WHATSAPP_CONTROL_RATE_LIMIT_MAX=20
WHATSAPP_SEND_RATE_LIMIT_WINDOW_MS=60000
WHATSAPP_SEND_RATE_LIMIT_MAX=40

# Opcional (fallback da ponte Chatwoot + Evolution)
# CHATWOOT_URL=http://20.226.48.76:8080
# CHATWOOT_ACCOUNT_ID=1
# CHATWOOT_INBOX_ID=1
# CHATWOOT_API_TOKEN=
# CHATWOOT_WEBHOOK_SECRET=
# EVOLUTION_URL=https://sua-evolution.exemplo.com
# EVOLUTION_API_KEY=
# EVOLUTION_INSTANCE=renovo-whatsapp
# EVOLUTION_WEBHOOK_SECRET=
# EVOLUTION_SYNC_MAX_ROWS=400
# CHATWOOT_OPERATIONAL_MAX_PAGES=20
